{
  "name": "simple-hotkeys",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.34.1",
  "engines": {
    "node": ">=20.12.0",
    "pnpm": ">=10.16.0"
  },
  "scripts": {
    "dev": "wxt",
    "dev:safari": "wxt -b safari",
    "build": "pnpm run build:chrome && pnpm run build:safari",
    "build:chrome": "wxt build -b chrome",
    "build:safari": "wxt build -b safari",
    "package:chrome": "wxt zip -b chrome",
    "package:safari": "wxt zip -b safari && ./scripts/package-safari.sh",
    "package:stores": "pnpm run package:chrome && pnpm run package:safari",
    "postinstall": "wxt prepare",
    "release:check": "pnpm test && pnpm typecheck && pnpm build",
    "test": "tsx --test tests/**/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsx": "4.22.3",
    "typescript": "6.0.3",
    "wxt": "0.20.26"
  }
}
